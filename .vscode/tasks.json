{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Restart backend api container",
			"type": "shell",
			"command": "docker compose -f backend/docker/docker-compose.yml restart api",
			"isBackground": false
		},
		{
			"label": "Check backend api container status",
			"type": "shell",
			"command": "docker compose -f backend/docker/docker-compose.yml ps api",
			"isBackground": false
		},
		{
			"label": "Check backend health endpoint",
			"type": "shell",
			"command": "curl -s http://localhost:3000/health",
			"isBackground": false
		},
		{
			"label": "Check backend categories endpoint",
			"type": "shell",
			"command": "curl -s http://localhost:3000/llm/categories",
			"isBackground": false
		},
		{
			"label": "Test backend topic stream",
			"type": "shell",
			"command": "curl -N -X POST http://localhost:3000/llm/topic -H 'Content-Type: application/json' -d '{\"mode\":\"surprise\",\"alreadyDiscovered\":[],\"dismissed\":[]}'",
			"isBackground": false
		},
		{
			"label": "Diag: list simulators",
			"type": "shell",
			"command": "xcrun simctl list devices available",
			"isBackground": false
		},
		{
			"label": "Diag: show destinations",
			"type": "shell",
			"command": "xcodebuild -workspace ios/Breadthwise.xcworkspace -scheme Breadthwise -showdestinations",
			"isBackground": false
		},
		{
			"label": "Verify: show destinations after SDKROOT fix",
			"type": "shell",
			"command": "xcodebuild -workspace ios/Breadthwise.xcworkspace -scheme Breadthwise -showdestinations",
			"isBackground": false
		},
		{
			"label": "Diag: inspect effective platform settings",
			"type": "shell",
			"command": "xcodebuild -workspace ios/Breadthwise.xcworkspace -scheme Breadthwise -showBuildSettings | rg \"SUPPORTED_PLATFORMS|SDKROOT|PLATFORM_NAME|TARGETED_DEVICE_FAMILY|SUPPORTS_MACCATALYST|EFFECTIVE_PLATFORM_NAME\" -n",
			"isBackground": false
		},
		{
			"label": "Diag: inspect platform settings with grep",
			"type": "shell",
			"command": "xcodebuild -workspace ios/Breadthwise.xcworkspace -scheme Breadthwise -showBuildSettings | grep -E \"SUPPORTED_PLATFORMS|SDKROOT|PLATFORM_NAME|TARGETED_DEVICE_FAMILY|SUPPORTS_MACCATALYST|EFFECTIVE_PLATFORM_NAME\"",
			"isBackground": false
		},
		{
			"label": "Diag: force iOS simulator destination",
			"type": "shell",
			"command": "xcodebuild -workspace ios/Breadthwise.xcworkspace -scheme Breadthwise -destination 'generic/platform=iOS Simulator' -showBuildSettings | grep -E 'PLATFORM_NAME|SUPPORTED_PLATFORMS|SDKROOT'",
			"isBackground": false
		},
		{
			"label": "Rebuild backend api container",
			"type": "shell",
			"command": "docker compose -f backend/docker/docker-compose.yml up -d --build api",
			"isBackground": false
		},
		{
			"label": "Rebuild api (one-off verify)",
			"type": "shell",
			"command": "docker compose -f backend/docker/docker-compose.yml up -d --build api && docker compose -f backend/docker/docker-compose.yml ps api",
			"isBackground": false
		},
		{
			"label": "Rebuild api after preflight route",
			"type": "shell",
			"command": "docker compose -f backend/docker/docker-compose.yml up -d --build api && docker compose -f backend/docker/docker-compose.yml ps api && curl -s http://localhost:3000/health",
			"isBackground": false
		}
	]
}