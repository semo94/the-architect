# Environment
NODE_ENV=development

# Server
PORT=3000

# Database
# Option 1: Local PostgreSQL (for development with Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_expansion

# Option 2: Neon PostgreSQL (for cloud development/production)
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# OAuth State Security (Generate with: openssl rand -base64 32)
OAUTH_STATE_SECRET=your_oauth_state_secret_min_32_chars

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars

# Client URLs
WEB_CLIENT_URL=http://localhost:3001
MOBILE_DEEP_LINK_SCHEME=breadthwise://

# Cookie Settings
COOKIE_DOMAIN=localhost
SECURE_COOKIES=false
COOKIE_SAME_SITE=lax

# Security
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000
ENABLE_FINGERPRINTING=true

# LLM Configuration
LLM_PROVIDER=anthropic
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://api.anthropic.com/v1/messages
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_ANTHROPIC_VERSION=2023-06-01
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7

# EMBEDDING Configuration
OPENAI_EMBEDDING_KEY=token
OPENAI_EMBEDDING_API_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Brave Search API key (for web search functionality)
BRAVE_API_KEY=token
BRAVE_API_URL=https://api.search.brave.com/res/v1/web/search

# Observability (optional) — DSN is the URL only, not "uptrace-dsn=..." (that prefix is for Uptrace YAML).
# When set: traces via OTLP to Uptrace; Pino logs via pino-opentelemetry-transport (JSON to stdout).
# Start scripts preload instrumentation-preload before the app (required for correct OTel init order).
UPTRACE_DSN=https://token@api.uptrace.dev?grpc=4317
OTEL_SERVICE_NAME=breadthwise-backend
LOG_LEVEL=info
# 512MB tuning when NODE_ENV=staging (code): SimpleSpanProcessor, HTTP+Undici only, NodeSDK traces-only.
# Logs: stdout on Render by default (OTEL_PINO_OTLP_TRANSPORT=true to send logs to Uptrace — needs headroom).
# Optional: OTEL_LOGS_EXPORT_ENABLED=false, OTEL_SPAN_PROCESSOR=batch|simple, OTEL_MEMORY_DIAGNOSTICS=true
# DB query logs are disabled in production unless this is explicitly true.
DB_LOG_QUERIES=false
